rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthed() {
      return request.auth != null;
    }

    function isAdminUser() {
      return isAuthed()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins Collection Rules
    match /admins/{uid} {
      // Admins can only read their own document to verify they are an admin.
      allow get: if isAuthed() && request.auth.uid == uid;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // Inscriptions Collection Rules
    match /inscriptions/{docId} {
      // 1. CREATE: Anyone can submit a registration form.
      // (Added basic check that status must be 'pending' is handled on client).
      allow create: if true;

      // 2. READ: Public read allowed temporarily for registration duplicate checking.
      // Warn: this allows anyone to read inscriptions. In prod, enforce safely with CFs.
      allow read: if true;

      // 3. UPDATE: Only Admins can update (e.g. changing status to validated/rejected).
      allow update: if isAdminUser();

      // 4. DELETE: Only Admins can delete inscriptions.
      // THIS IS THE RULE THAT FIXES THE PERMISSION ERROR!
      allow delete: if isAdminUser();
    }
  }
}
